        J3[Denial Letter]
    end

    subgraph "PHASE 8 — LICENSE Order 299"
        K1[Draft License Agreement]
        K2[Applicant: Agreement<br/>Review & Payment]
        K3[Legal Review of<br/>Payment & License]
        K4[Issue License Agreement<br/>CEO]
    end

    subgraph "PHASE 9 — MINISTERIAL Order 299"
        L1[Preparation of<br/>Ministerial Bundle]
        L2[MIC Instructions]
        L3[Draft Ministerial Order]
        L4[Ministerial Order<br/>Legal Review]
        L5[Ministerial Order<br/>Approval]
