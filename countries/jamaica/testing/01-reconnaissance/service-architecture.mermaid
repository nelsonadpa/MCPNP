    %% Flow connections
    A5 --> B1
    B1 --> C1 & C2 & C3 & C4 & C5
    B1 --> D1 & D2 & D3

    C1 --> E7
    C2 --> E5
    C3 --> E4
    C4 --> E6
    D1 --> E1
    D2 --> E2
    D3 --> E3

    E1 & E2 & E3 & E4 & E5 & E6 & E7 --> F1

    F1 -->|Needs info| G1
    G1 --> G2
    G2 --> F1

    F1 --> H1 --> H2
    H2 --> I1 --> I2 --> I3
    I3 --> J1

    J1 -->|Approved| J2
    J1 -->|Denied| J3

    J2 --> K1 --> K2 --> K3 --> K4
    J2 --> L1 --> L2 --> L3 --> L4 --> L5 --> L6

    K4 --> M1 --> M2 --> M3 --> M4 --> M5
    K4 --> N1 --> N2 --> N3 --> N4

    %% Styling
    classDef applicant fill:#e3f2fd,stroke:#1565c0
    classDef intake fill:#fff3e0,stroke:#e65100
    classDef eval fill:#f3e5f5,stroke:#7b1fa2
    classDef approval fill:#e8f5e9,stroke:#2e7d32
