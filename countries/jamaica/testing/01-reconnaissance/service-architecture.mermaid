        E5[Technical Approval<br/>Dir. Technical Services]
        E6[Compliance Approval<br/>COO]
        E7[Legal Approval<br/>Sr. Dir. Legal Services]
    end

    subgraph "PHASE 5 — COMMITTEE Order 3"
        F1[ARC — Application<br/>Reviewing Committee]
    end

    subgraph "CORRECTION LOOP"
        G1[Complementary<br/>Information]
        G2[Applicant corrects<br/>& resubmits]
    end

    subgraph "PHASE 6 — STATUS Order 5-6"
        H1[Status Letter<br/>Preparation]
        H2[Signature<br/>Status Letter]
    end

    subgraph "PHASE 7 — BOARD Order 7-10"
