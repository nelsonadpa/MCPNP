%% ID: d51d6c78-5ead-c948-0b82-0d9bc71cd712

graph TD
    subgraph "APPLICANT"
        A1[Applicant fills form<br/>469 components, 63 panels]
        A2[Upload 33 documents]
        A3[Sign consents & undertaking]
        A4[Digital payment]
        A5[Submit application]
        A1 --> A2 --> A3 --> A4 --> A5
    end

    subgraph "PHASE 1 — INTAKE"
        B1[Documents Check<br/>Order 0]
    end

    subgraph "PHASE 2 — PARALLEL EVALUATIONS Order 1"
