  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '--- Session Start: Manual Agent (Read-Only) ---' && echo '=== Pending Requests ===' && ls ~/Desktop/OCAgents/shared/requests/*manual* 2>/dev/null || echo 'No pending requests for manual agent' && echo '=== CHANGELOG (last 30 lines) ===' && tail -30 ~/Desktop/OCAgents/shared/knowledge/CHANGELOG.md 2>/dev/null && echo '=== Notifications ===' && ~/Desktop/OCAgents/shared/notify.sh check manual 2>/dev/null && ~/Desktop/OCAgents/shared/notify.sh clean manual 2>/dev/null"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_FILE_PATH\" | grep -q 'shared/responses/'; then BASENAME=$(basename \"$CLAUDE_FILE_PATH\" .md); TARGET=$(echo \"$BASENAME\" | sed 's/^[^-]*-//; s/_.*//' | head -c 20); ~/Desktop/OCAgents/shared/notify.sh signal \"$TARGET\" manual \"$BASENAME\" RESPONSE 2>/dev/null; fi"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__BPA-cuba__.*(_create|_update|_delete|_publish|_activate|_save|_remove|_move)",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'BLOCKED: Manual Agent is READ-ONLY. Send modification requests to Config Agent via shared/requests/.' && exit 1"
          }
        ]
      },
      {
        "matcher": "mcp__BPA-lesotho2__.*(_create|_update|_delete|_publish|_activate|_save|_remove|_move)",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'BLOCKED: Manual Agent is READ-ONLY. Send modification requests to Config Agent via shared/requests/.' && exit 1"
          }
        ]
      },
      {
        "matcher": "mcp__BPA-colombia-test__.*(_create|_update|_delete|_publish|_activate|_save|_remove|_move)",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'BLOCKED: Manual Agent is READ-ONLY. Send modification requests to Config Agent via shared/requests/.' && exit 1"
          }
        ]
      },
      {
        "matcher": "mcp__BPA-jamaica__.*(_create|_update|_delete|_publish|_activate|_save|_remove|_move)",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'BLOCKED: Manual Agent is READ-ONLY. Send modification requests to Config Agent via shared/requests/.' && exit 1"
          }
        ]
      }
    ]
  },
  "_comments": {
    "mcp_servers": "This agent uses BPA-cuba, BPA-lesotho2 (and optionally BPA-colombia-test, BPA-jamaica) in READ-ONLY mode. All write tools are explicitly denied and blocked by PreToolUse hooks.",
    "role": "Manual Agent (Extractor) — read-only knowledge provider across 4 MCP instances"
  }
}
