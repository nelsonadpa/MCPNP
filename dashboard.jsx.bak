  // ══════════════════════════════════════════════════════════
  // TAB RENDERER
  // ══════════════════════════════════════════════════════════
  function renderActiveTab() {
    if (activeTab === 0) return renderCommandCenter();
    if (activeTab === 1) return renderReviewQueue();
    if (activeTab === 2) return renderMissions();
    if (activeTab === 3) return renderAgents();
    if (activeTab === 4) return renderInstitutionalization();
    if (activeTab === 5) return renderKnowledge();
    if (activeTab === 6) return renderDecisions();
    if (activeTab === 7) return renderProtocolo();
    if (activeTab === 8) return renderHowItWorks();
    if (activeTab === 9) return renderCommsLog();
    return null;
  }

  // ══════════════════════════════════════════════════════════
  // TAB 9: HOW IT WORKS
  // ══════════════════════════════════════════════════════════
  function renderHowItWorks() {
    var demoPrompt = 'Conectar servicio CENASA Registro Zoosanitario a la Bitacora. ' +
      'Paso 1: Que el Manual Agent extraiga la estructura completa del servicio (formulario, fields, blocks). ' +
      'Paso 2: Que el Config Agent cree el determinant StatusBitacora + effect + panel "Su empresa seleccionada". ' +
      'Paso 3: Que el Test Agent genere y ejecute tests E2E validando el flujo completo.';

    // Intro
    var intro = React.createElement(
      "div",
      {
        style: Object.assign({}, cardStyle(), {
          borderLeft: "4px solid " + COLORS.orchestrator,
        }),
      },
      React.createElement(
        "div",
        {
          style: {
            fontSize: "16px",
            fontWeight: "800",
            color: theme.text,
            fontFamily: fontMono,
            marginBottom: "12px",
          },
        },
        "Multi-Agent Orchestration Demo"
      ),
      React.createElement(
        "div",
        { style: { fontSize: "13px", color: theme.sub, lineHeight: "1.7", marginBottom: "16px" } },
        "Este ejemplo muestra como un solo prompt al Orquestador desencadena acciones coordinadas ",
        "entre los 3 agentes, generando comunicacion, conocimiento y validacion automatica."
      ),
      React.createElement(
        "div",
        {
          style: {
            fontSize: "11px",
            fontFamily: fontMono,
            letterSpacing: "2px",
            textTransform: "uppercase",
            color: theme.dim,
            marginBottom: "8px",
          },
        },
        "PROMPT EXACTO AL ORQUESTADOR"
      ),
      React.createElement(
        "div",
        {
          style: {
            padding: "14px 16px",
            background: theme.codeBg,
            borderRadius: "8px",
            border: "1px solid " + COLORS.orchestrator + "44",
            fontSize: "13px",
            fontFamily: fontMono,
            color: COLORS.orchestrator,
            lineHeight: "1.6",
            cursor: "pointer",
          },
          title: "Click para copiar",
          onClick: function () {
            if (navigator.clipboard) {
              navigator.clipboard.writeText(demoPrompt);
            }
          },
        },
        "> " + demoPrompt
      )
    );

    // Timeline steps
    var steps = [
      {
        num: "1",
        agent: "Orchestrator",
        color: COLORS.orchestrator,
        letter: "O",
        title: "Recibe y descompone la orden",
        desc: "El orquestador analiza el prompt, identifica 3 sub-tareas y lanza agentes en secuencia.",
        produces: "Lanza Manual Agent como subagente con prompt especifico",
        files: [],
      },
      {
        num: "2",
        agent: "Manual Agent",
        color: COLORS.manual,
        letter: "M",
        title: "Extrae estructura del servicio via MCP",
        desc: "Conecta a BPA-cuba, ejecuta service_get + form_get + field_list + bot_list para CENASA. Escribe la respuesta estructurada.",
        produces: "shared/responses/manual-config_NNN.md con formulario completo",
        files: [
          "shared/responses/manual-config_NNN.md",
          "shared/knowledge/cenasa-extraction.md",
        ],
      },
      {
        num: "3",
        agent: "Config Agent",
        color: COLORS.config,
        letter: "C",
        title: "Configura determinant + effect + panel",
        desc: "Lee la extraccion del Manual, identifica el target block, crea StatusBitacora via REST API, crea effect + panel mustache con NIT y Empresa.",
        produces: "Cambios en BPA-cuba + CHANGELOG actualizado",
        files: [
          "shared/knowledge/CHANGELOG.md (nueva entrada)",
          "BPA-cuba: determinant + behaviour + effect (via MCP)",
          "BPA-cuba: panel 'Su empresa seleccionada' (via MCP)",
        ],
      },
      {
        num: "4",
        agent: "Test Agent",
        color: COLORS.test,
        letter: "T",
        title: "Genera y ejecuta tests E2E",
        desc: "Lee la extraccion del Manual + CHANGELOG del Config. Genera spec Playwright que navega Bitacora -> selecciona empresa -> entra a CENASA -> verifica que Block12 aparece.",
        produces: "testing/tests/specs/cenasa.spec.ts + resultados",
        files: [
          "testing/tests/specs/cenasa.spec.ts",
          "testing/tests/pages/CenasaPage.ts",
          "test-results/ (screenshots)",
        ],
      },
      {
        num: "5",
        agent: "Orchestrator",
        color: COLORS.orchestrator,
        letter: "O",
        title: "Consolida y reporta",
        desc: "Recibe resultados de los 3 agentes. Actualiza MISSIONS.md, genera SITREP, actualiza dashboard.",
        produces: "SITREP + MISSIONS.md actualizado + dashboard refresh",
        files: [
          "shared/MISSIONS.md (progreso +1)",
          "shared/sitreps/SITREP-YYYY-MM-DD.md",
          "dashboard.jsx (via /dashboard-update)",
        ],
      },
    ];

    var timeline = React.createElement(
      "div",
      { style: { marginTop: "24px" } },
      sectionTitle("Flujo paso a paso"),
      steps.map(function (step, idx) {
        return React.createElement(
          "div",
          {
            key: idx,
            style: {
              display: "flex",
              gap: "16px",
              marginBottom: "0",
            },
          },
          // Left line
          React.createElement(
            "div",
            {
              style: {
                display: "flex",
                flexDirection: "column",
                alignItems: "center",
                minWidth: "40px",
              },
            },
            iconCircle(step.letter, step.color, 36),
            idx < steps.length - 1
              ? React.createElement("div", {
                  style: {
                    width: "2px",
                    flex: 1,
                    background: step.color + "44",
                    minHeight: "20px",
                  },
                })
              : null
          ),
          // Right content
          React.createElement(
            "div",
            {
              style: Object.assign({}, cardStyle(), {
                flex: 1,
                borderLeft: "3px solid " + step.color,
                marginBottom: "12px",
              }),
            },
            React.createElement(
              "div",
              {
                style: {
                  display: "flex",
                  alignItems: "center",
                  gap: "10px",
                  marginBottom: "8px",
                },
              },
              React.createElement(
                "span",
                {
