              "Crear component action en boton de Block22",
            ],
          },
          {
            agent: "Test Agent",
            color: COLORS.test,
            letter: "T",
            examples: [
              "Generar tests E2E para el servicio Zoosanitario",
              "Ejecutar tests de block22 permisos",
              "Pedir al Manual la estructura antes de generar specs",
              "Validar que bot LISTAR devuelve resultados",
            ],
          },
        ].map(function (ag, idx) {
          return React.createElement(
            "div",
            {
              key: idx,
              style: Object.assign({}, cardStyle(), {
                borderLeft: "4px solid " + ag.color,
                marginBottom: "0",
              }),
            },
            React.createElement(
              "div",
              {
                style: {
                  display: "flex",
                  alignItems: "center",
                  gap: "10px",
                  marginBottom: "12px",
                },
              },
              iconCircle(ag.letter, ag.color, 28),
              React.createElement(
                "span",
                {
                  style: {
                    fontWeight: "700",
