  // ══════════════════════════════════════════════════════════
  // TAB 10: COMMS LOG
  // ══════════════════════════════════════════════════════════

  var commsLog = [
    {
      type: "request",
      id: "test-manual_001",
      from: "Test Agent",
      fromColor: COLORS.testing,
      to: "Manual Agent",
      toColor: COLORS.manual,
      date: "2026-02-21",
      time: "16:17",
      priority: "ALTA",
      subject: "Estructura formularios Acreditaciones + Bitacora buttons",
      reason: "34/34 tests pasan para Bitacora dashboard. Necesita ir mas profundo: formularios de Acreditaciones, ONURE, Cert. Sanitario y flujos de botones del dashboard.",
      file: "test->manual_001.md",
      path: "/Users/nelsonperez/Desktop/OCAgents/shared/requests/test->manual_001.md",
      serviceId: "2c918084887c7a8f01888b72010c7d6e",
      serviceName: "Acreditaciones",
      items: [
        "Formulario 'Acreditarse en otra empresa' - estructura completa",
        "Formulario ONURE equipos - panels, campos, determinantes",
        "Formulario Cert. Sanitario - estructura completa",
        "Bitacora: que hace cada boton en Block22 (Agregar permiso)"
      ]
    },
    {
      type: "response",
      id: "test-manual_001",
      from: "Manual Agent",
      fromColor: COLORS.manual,
      to: "Test Agent",
      toColor: COLORS.testing,
      date: "2026-02-21",
      time: "16:40",
      priority: "COMPLETA",
      subject: "Estructuras completas de 3 formularios + mapeo de botones",
      reason: "Extraccion via MCP BPA-Cuba de los 3 formularios solicitados mas analisis de Component Actions en Block22.",
      file: "test-manual_001.md",
      path: "/Users/nelsonperez/Desktop/OCAgents/shared/responses/test-manual_001.md",
      serviceId: "multiple",
      serviceName: "Acreditaciones + ONURE + Sanitario + Bitacora",
      items: [
        "Acreditaciones: 45 componentes, 3 paneles principales, formulario completo",
        "ONURE Equipos: estructura con tabs, campos especificos de energia",
        "Cert. Sanitario: formulario multi-seccion con controles fitosanitarios",
        "Bitacora Block22: mapeo completo de 8 botones a Component Actions y bots"
      ]
    }
  ];

  function renderCommsLog() {
    // Stats
    var reqCount = 0;
    var resCount = 0;
    var agents = {};
    for (var i = 0; i < commsLog.length; i++) {
      if (commsLog[i].type === "request") reqCount++;
      if (commsLog[i].type === "response") resCount++;
      agents[commsLog[i].from] = true;
      agents[commsLog[i].to] = true;
    }
    var agentCount = Object.keys(agents).length;

    // Stats bar
    var statsBar = React.createElement(
      "div",
      {
        style: {
          display: "flex",
          gap: "16px",
          marginBottom: "20px",
          flexWrap: "wrap",
        },
      },
      React.createElement(
        "div",
        {
          style: Object.assign({}, cardStyle(), {
            flex: 1,
            minWidth: "120px",
            textAlign: "center",
            padding: "16px",
          }),
        },
        React.createElement("div", {
          style: { fontSize: "28px", fontWeight: "800", color: COLORS.testing, fontFamily: fontMono }
        }, String(reqCount)),
        React.createElement("div", {
          style: { fontSize: "11px", color: theme.dim, fontFamily: fontMono, letterSpacing: "2px", textTransform: "uppercase", marginTop: "4px" }
        }, "Requests")
      ),
      React.createElement(
        "div",
        {
          style: Object.assign({}, cardStyle(), {
            flex: 1,
            minWidth: "120px",
            textAlign: "center",
            padding: "16px",
          }),
        },
        React.createElement("div", {
          style: { fontSize: "28px", fontWeight: "800", color: COLORS.done, fontFamily: fontMono }
        }, String(resCount)),
        React.createElement("div", {
          style: { fontSize: "11px", color: theme.dim, fontFamily: fontMono, letterSpacing: "2px", textTransform: "uppercase", marginTop: "4px" }
        }, "Responses")
      ),
      React.createElement(
        "div",
        {
          style: Object.assign({}, cardStyle(), {
            flex: 1,
            minWidth: "120px",
            textAlign: "center",
            padding: "16px",
          }),
        },
        React.createElement("div", {
          style: { fontSize: "28px", fontWeight: "800", color: COLORS.orchestrator, fontFamily: fontMono }
        }, String(agentCount)),
        React.createElement("div", {
          style: { fontSize: "11px", color: theme.dim, fontFamily: fontMono, letterSpacing: "2px", textTransform: "uppercase", marginTop: "4px" }
        }, "Agents activos")
      ),
      React.createElement(
        "div",
        {
          style: Object.assign({}, cardStyle(), {
            flex: 1,
            minWidth: "120px",
            textAlign: "center",
            padding: "16px",
          }),
        },
        React.createElement("div", {
          style: { fontSize: "28px", fontWeight: "800", color: reqCount > resCount ? COLORS.warn : COLORS.done, fontFamily: fontMono }
        }, String(reqCount - resCount)),
        React.createElement("div", {
          style: { fontSize: "11px", color: theme.dim, fontFamily: fontMono, letterSpacing: "2px", textTransform: "uppercase", marginTop: "4px" }
        }, "Pendientes")
      )
    );

    // Protocol explainer
    var protocolCard = React.createElement(
      "div",
      {
        style: Object.assign({}, cardStyle(), {
          borderLeft: "4px solid " + COLORS.orchestrator,
          marginBottom: "20px",
        }),
      },
      React.createElement("div", {
        style: { fontSize: "11px", fontFamily: fontMono, letterSpacing: "2px", textTransform: "uppercase", color: theme.dim, marginBottom: "8px" }
      }, "PROTOCOLO DE COMUNICACION"),
      React.createElement("div", {
        style: { fontSize: "13px", color: theme.sub, lineHeight: "1.7" }
      },
        "Los agentes se comunican via archivos markdown en shared/. ",
        "Requests van en shared/requests/[from]-[to]_NNN.md y responses en shared/responses/[to]-[from]_NNN.md. ",
        "Cada archivo incluye fecha, prioridad, contexto y lo que se necesita."
      )
    );

    // Timeline entries
    var timelineEntries = [];
    for (var j = 0; j < commsLog.length; j++) {
      (function(entry, idx) {
        var isReq = entry.type === "request";
        var accentColor = isReq ? entry.fromColor : COLORS.done;
        var typeLabel = isReq ? "REQUEST" : "RESPONSE";
        var arrow = isReq ? " -> " : " <- ";
        var dirLabel = isReq
          ? entry.from + arrow + entry.to
          : entry.to + arrow + entry.from;

        // Items list
        var itemElements = [];
        if (entry.items) {
          for (var k = 0; k < entry.items.length; k++) {
            itemElements.push(
              React.createElement("div", {
                key: "item-" + k,
                style: {
                  fontSize: "12px",
                  color: theme.sub,
                  padding: "4px 0",
                  paddingLeft: "16px",
                  borderLeft: "2px solid " + accentColor + "33",
                  marginBottom: "4px",
                }
              }, entry.items[k])
            );
          }
        }

        var card = React.createElement(
          "div",
          {
            key: "comm-" + idx,
            style: Object.assign({}, cardStyle(), {
              borderLeft: "4px solid " + accentColor,
              position: "relative",
            }),
          },
          // Header row: type badge + direction + date/time
          React.createElement(
            "div",
            {
              style: {
                display: "flex",
                alignItems: "center",
                gap: "10px",
                marginBottom: "12px",
                flexWrap: "wrap",
              },
            },
            React.createElement("span", {
              style: badgeStyle(accentColor + "22", accentColor)
            }, typeLabel),
            React.createElement("span", {
              style: {
                fontSize: "13px",
                fontWeight: "700",
                fontFamily: fontMono,
                color: theme.text,
              }
            }, dirLabel),
            React.createElement("span", {
              style: {
                fontSize: "11px",
                fontFamily: fontMono,
                color: theme.dim,
                marginLeft: "auto",
              }
            }, entry.date + " " + entry.time),
            entry.priority ? React.createElement("span", {
              style: badgeStyle(
                entry.priority === "ALTA" ? COLORS.warn + "22" : COLORS.done + "22",
                entry.priority === "ALTA" ? COLORS.warn : COLORS.done
              )
            }, entry.priority) : null
          ),
          // Subject
          React.createElement("div", {
            style: {
              fontSize: "14px",
              fontWeight: "700",
              color: theme.text,
              marginBottom: "8px",
            }
          }, entry.subject),
          // Reason
          React.createElement("div", {
            style: {
              fontSize: "13px",
              color: theme.sub,
              lineHeight: "1.6",
              marginBottom: "12px",
              padding: "10px 12px",
              background: theme.codeBg,
              borderRadius: "8px",
            }
          }, entry.reason),
          // Items
          itemElements.length > 0 ? React.createElement(
            "div",
            { style: { marginBottom: "12px" } },
            React.createElement("div", {
              style: { fontSize: "11px", fontFamily: fontMono, letterSpacing: "2px", textTransform: "uppercase", color: theme.dim, marginBottom: "8px" }
            }, isReq ? "LO QUE SE PIDE" : "LO QUE SE ENTREGO"),
            React.createElement("div", null, itemElements)
          ) : null,
          // Footer: file link + service
          React.createElement(
            "div",
            {
              style: {
                display: "flex",
                alignItems: "center",
                gap: "12px",
                flexWrap: "wrap",
                paddingTop: "8px",
                borderTop: "1px solid " + theme.cardBorder,
              },
            },
            React.createElement("a", {
              href: "file://" + entry.path,
              style: {
                fontSize: "11px",
                fontFamily: fontMono,
                color: accentColor,
                textDecoration: "none",
                borderBottom: "1px dashed " + accentColor + "66",
              }
            }, entry.file),
            entry.serviceName ? React.createElement("span", {
              style: {
                fontSize: "11px",
                fontFamily: fontMono,
                color: theme.dim,
              }
            }, "Servicio: " + entry.serviceName) : null
          )
        );

        timelineEntries.push(card);
      })(commsLog[j], j);
    }

    // Empty state if no entries
    if (commsLog.length === 0) {
      timelineEntries.push(
        React.createElement(
          "div",
          {
            key: "empty",
            style: Object.assign({}, cardStyle(), {
              textAlign: "center",
              padding: "48px 20px",
            }),
          },
          React.createElement("div", {
            style: { fontSize: "48px", marginBottom: "16px", color: theme.dim }
          }, "[--]"),
          React.createElement("div", {
            style: { fontSize: "16px", fontWeight: "700", color: theme.text, fontFamily: fontMono }
          }, "No hay comunicaciones registradas"),
          React.createElement("div", {
            style: { fontSize: "13px", color: theme.sub, marginTop: "8px" }
          }, "Los agentes aun no han intercambiado requests/responses.")
        )
      );
    }

    var timelineSection = React.createElement("div", null, timelineEntries);

    // Folder links
    var folderLinks = React.createElement(
      "div",
      {
        style: {
          display: "flex",
          gap: "12px",
          marginTop: "8px",
          marginBottom: "20px",
          flexWrap: "wrap",
        },
      },
      React.createElement("a", {
        href: "file:///Users/nelsonperez/Desktop/OCAgents/shared/requests/",
        style: {
          fontSize: "11px",
          fontFamily: fontMono,
          padding: "6px 14px",
          borderRadius: "8px",
          background: COLORS.testing + "15",
          color: COLORS.testing,
          textDecoration: "none",
          border: "1px solid " + COLORS.testing + "33",
        }
      }, "shared/requests/"),
      React.createElement("a", {
        href: "file:///Users/nelsonperez/Desktop/OCAgents/shared/responses/",
        style: {
          fontSize: "11px",
          fontFamily: fontMono,
          padding: "6px 14px",
          borderRadius: "8px",
          background: COLORS.done + "15",
          color: COLORS.done,
          textDecoration: "none",
          border: "1px solid " + COLORS.done + "33",
        }
      }, "shared/responses/")
    );

    return React.createElement("div", null, statsBar, protocolCard, folderLinks, timelineSection);
  }

  // ══════════════════════════════════════════════════════════
  // MAIN RENDER
