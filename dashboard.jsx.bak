    );

    // Example agent usage
    var usageExamples = React.createElement(
      "div",
      { style: { marginTop: "24px" } },
      sectionTitle("Ejemplos de uso de cada agente"),
      React.createElement(
        "div",
        {
          style: {
            display: "grid",
            gridTemplateColumns: "repeat(auto-fit, minmax(300px, 1fr))",
            gap: "12px",
          },
        },
        [
          {
            agent: "Manual Agent",
            color: COLORS.manual,
            letter: "M",
            examples: [
              "Extraer estructura completa de un servicio",
              "Comparar servicio PE entre Cuba y Lesotho",
              "Generar manual HTML navegable de Zoosanitario",
