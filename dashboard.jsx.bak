        );
      })
    );

    // What changes in the dashboard
    var dashboardImpact = React.createElement(
      "div",
      { style: { marginTop: "24px" } },
      sectionTitle("Que cambia en el Dashboard"),
      React.createElement(
        "div",
        {
          style: {
